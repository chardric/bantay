# Bantay local Docker stack
# Copy to .env and edit. Never commit .env.

# --- Hub (PocketBase web UI) ---
HUB_PORT=8090
TZ=Asia/Manila
# Optional admin auto-login (dev convenience). Leave empty in production.
AUTO_LOGIN=
# Phone home for update notifications (true/false).
CHECK_UPDATES=false
# Show per-container metrics in the UI (true/false).
CONTAINER_DETAILS=true

# --- Agent ---
# Required. The hub generates an SSH ed25519 keypair on first start; copy the
# public key shown in the UI under "Add System" and paste it here.
# install.sh prints instructions if this is empty.
KEY=

# Port the agent listens on (host network).
AGENT_LISTEN=45876
AGENT_LOG_LEVEL=info
# Comma-separated extra filesystems to monitor, e.g. "sda1,nvme0n1p2".
EXTRA_FILESYSTEMS=

# --- Backup (offen/docker-volume-backup) ---
# Daily at 03:00 local time. Retains 7 days of archives in ./backups/.
BACKUP_CRON_EXPRESSION=0 3 * * *
BACKUP_FILENAME=bantay-%Y-%m-%dT%H-%M-%S.tar.gz
BACKUP_PRUNING_PREFIX=bantay-
BACKUP_RETENTION_DAYS=7

# Off-site / encryption (optional). Uncomment + fill to enable.
# Encrypts each archive with symmetric GPG.
# GPG_PASSPHRASE=
# Off-site S3-compatible target (Minio, Backblaze B2, etc.).
# AWS_S3_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT=

# --- Build ---
# Tag suffix for locally built images (bantay-local/hub:<tag>, bantay-local/agent:<tag>).
BANTAY_VERSION=local
